# ── Seguridad ─────────────────────────────────────────────────────────────────
# Generá una clave con: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=cambiar-en-produccion

DEBUG=False
ALLOWED_HOSTS=sociosras.supregsolutions.com,www.sociosras.supregsolutions.com
CSRF_TRUSTED_ORIGINS=https://sociosras.supregsolutions.com,https://www.sociosras.supregsolutions.com

# ── Base de datos ─────────────────────────────────────────────────────────────
POSTGRES_DB=waply
POSTGRES_USER=waply
POSTGRES_PASSWORD=waply123
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Proveedor de WhatsApp ─────────────────────────────────────────────────────
# 'meta' (Cloud API oficial, más barato) o 'twilio' (intermediario / BSP).
# Se puede cambiar también desde Configuración en la app; este es el valor por defecto.
WHATSAPP_PROVIDER=meta

# ── WhatsApp Cloud API (Meta) ─────────────────────────────────────────────────
# Generá estos datos en developers.facebook.com → tu app → WhatsApp → Configuración de la API
# META_ACCESS_TOKEN: token permanente (System User en Business Manager, no el temporal de 24hs)
META_ACCESS_TOKEN=
# ID del número de teléfono (no es el número en sí), en "Configuración de la API"
META_PHONE_NUMBER_ID=
# ID de la cuenta de WhatsApp Business (WABA), se usa para administrar Plantillas
META_WABA_ID=
# App Secret de la app de Meta (Configuración → Básica), para verificar la firma del webhook
META_APP_SECRET=
META_API_VERSION=v21.0

# ── Webhook ───────────────────────────────────────────────────────────────────
# Verify token inventado por vos: se pega en Meta → WhatsApp → Configuración → Webhook
# al suscribirlo (handshake hub.verify_token), y acá para validarlo.
WHATSAPP_VERIFY_TOKEN=token-secreto

# ── Twilio (solo si WHATSAPP_PROVIDER=twilio) ─────────────────────────────────
# Account SID y Auth Token están en el dashboard de Twilio (console.twilio.com).
# El Auth Token también valida la firma (X-Twilio-Signature) del webhook entrante.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Número de WhatsApp habilitado en Twilio, en formato E.164 (sin el prefijo whatsapp:)
TWILIO_WHATSAPP_FROM=

# ── URL pública ───────────────────────────────────────────────────────────────
PUBLIC_URL=https://sociosras.supregsolutions.com

# ── n8n (opcional) ────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=
N8N_LIBERAR_ASESOR_URL=
CRM_API_KEY=
